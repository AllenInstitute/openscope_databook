ng file\n"},"children":[],"key":"cGv4b4nhd7"}],"key":"Vw2BLMkQpG"}],"key":"bVtAJWE0e3"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Extracting NWB CCF Coordinates","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"WmCjrUUypw"}],"identifier":"extracting-nwb-ccf-coordinates","label":"Extracting NWB CCF Coordinates","html_id":"extracting-nwb-ccf-coordinates","implicit":true,"key":"kmOcpsqVQ4"},{"type":"paragraph","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"Here, you can read the NWB file you’re interested in viewing. Specify your file of interest’s relative file path in ","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"o8KC9fnW9N"},{"type":"inlineCode","value":"nwb_filepath","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"NKnUqiklVJ"},{"type":"text","value":". From there, the file will be read and the probe unit coordinates will be extracted and turned into a numpy array.","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"ywW5tlwnSM"}],"key":"jiqNSnB6F4"},{"type":"paragraph","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"Note that this will only work with ecephys NWB files which have a valid ","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"HM4DHa5nuN"},{"type":"emphasis","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"electrodes","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"ZlvCb5g37s"}],"key":"svxf8EE70p"},{"type":"text","value":" field.","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"WSMGHCh3XI"}],"key":"v1sqf5iGNg"}],"key":"cYtMNNMluq"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"### read the x,y,z ccf coordinates and generate points\nxs = nwb.electrodes.x\nys = nwb.electrodes.y\nzs = nwb.electrodes.z\nn = min(len(xs), len(ys), len(zs))\npoints = np.array([[xs[i], ys[i], zs[i]] for i in range(n)])","key":"PBaVRiTE63"},{"type":"outputs","id":"GaEsWq--I0i5Y6aRsJDhf","children":[],"key":"a8ok7kBHP4"}],"key":"nASw3YfWLN"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# each point has 3 coordinates associated with it\nprint(points.shape)","key":"N2WdvFISjF"},{"type":"outputs","id":"WfJQ9RC9KqUgve0tSX30M","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"(2304, 3)\n"},"children":[],"key":"Ddbzw6T4Fg"}],"key":"M3h4mFQm1H"}],"key":"DBKJ1vVnJj"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Rendering","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"wfQ6x4Our9"}],"identifier":"rendering","label":"Rendering","html_id":"rendering","implicit":true,"key":"AsHisIH2xg"},{"type":"paragraph","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"We build an interactive 3D scene with Plotly: the whole-brain CCF surface is drawn as a semi-transparent mesh, and each electrode’s CCF coordinate is plotted as a point inside it. The scene renders inline below and is also saved as a standalone ","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"j8iincQVAB"},{"type":"inlineCode","value":"neuropixels_probe_locations.html","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"dzYe3SeyZQ"},{"type":"text","value":" file you can open in any browser.","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"XwbHo4Rj4d"}],"key":"syzVmRkIsh"}],"key":"gTscndZy0T"},{"type":"block","kind":"notebook-code","data":{"tags":["skip-execution"]},"children":[{"type":"code","lang":"python","executable":true,"value":"import os\nimport urllib.request\n\n# Whole-brain CCF surface mesh from the Allen Institute (cached locally after first download).\nbrain_mesh_url = \"http://download.alleninstitute.org/informatics-archive/current-release/mouse_ccf/annotation/ccf_2017/structure_meshes/997.obj\"\nbrain_mesh_file = \"ccf_root_mesh.obj\"\n\nif not os.path.exists(brain_mesh_file):\n    request = urllib.request.Request(brain_mesh_url, headers={\"User-Agent\": \"Mozilla/5.0\"})\n    with urllib.request.urlopen(request, timeout=120) as response, open(brain_mesh_file, \"wb\") as out_file:\n        out_file.write(response.read())\n\n# Parse the OBJ mesh into vertices and triangular faces (OBJ indices are 1-based)\nmesh_vertices = []\nmesh_faces = []\nwith open(brain_mesh_file) as mesh_file:\n    for line in mesh_file:\n        if line.startswith(\"v \"):\n            _, vx, vy, vz = line.split()[:4]\n            mesh_vertices.append((float(vx), float(vy), float(vz)))\n        elif line.startswith(\"f \"):\n            face = [int(part.split(\"/\")[0]) - 1 for part in line.split()[1:]]\n            mesh_faces.append(face[:3])\n\nmesh_vertices = np.array(mesh_vertices)\nmesh_faces = np.array(mesh_faces)\n\n# Keep only electrodes with valid CCF coordinates (finite and inside the brain volume)\nvalid = np.all(np.isfinite(points), axis=1) & np.all(points > 0, axis=1)\nprobe_points = points[valid]\nprint(f\"Rendering {len(probe_points)} of {len(points)} electrode locations\")\n","visibility":"show","key":"CKTrMQCPnB"},{"type":"outputs","id":"zGzyKqZmAQ_2CddScN6J7","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Rendering 2184 of 2304 electrode locations\n"},"children":[],"key":"Afsz7NXMef"}],"visibility":"show","key":"BjhP85XswE"}],"visibility":"show","key":"iJ0XZYLLnq"},{"type":"block","kind":"notebook-code","data":{"tags":["skip-execution"]},"children":[{"type":"code","lang":"python","executable":true,"value":"brain_surface = go.Mesh3d(\n    x=mesh_vertices[:, 0], y=mesh_vertices[:, 1], z=mesh_vertices[:, 2],\n    i=mesh_faces[:, 0], j=mesh_faces[:, 1], k=mesh_faces[:, 2],\n    color=\"lightgray\", opacity=0.15, hoverinfo=\"skip\", name=\"CCF brain\",\n)\nelectrodes = go.Scatter3d(\n    x=probe_points[:, 0], y=probe_points[:, 1], z=probe_points[:, 2],\n    mode=\"markers\",\n    marker=dict(size=2, color=probe_points[:, 1], colorscale=\"Viridis\"),\n    name=\"electrodes\",\n)\n\nfig = go.Figure(data=[brain_surface, electrodes])\nfig.update_layout(\n    title=\"Neuropixels electrode CCF locations\",\n    scene=dict(\n        xaxis_title=\"anterior → posterior (µm)\",\n        yaxis_title=\"dorsal → ventral (µm)\",\n        zaxis_title=\"left → right (µm)\",\n        yaxis=dict(autorange=\"reversed\"),\n        aspectmode=\"data\",\n    ),\n    margin=dict(l=0, r=0, t=30, b=0),\n)\n\n# Save a self-contained interactive HTML/JavaScript render that opens in any browser\nfig.write_html(\"neuropixels_probe_locations.html\", include_plotlyjs=\"cdn\")\nfig\n","visibility":"show","key":"MaDAe7cqWa"},{"type":"outputs","id":"sn9nHc__yBuvtAyJ2lGBL","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"application/vnd.plotly.v1+json":{"content_type":"application/vnd.plotly.v1+json","hash":"8499ee025631edb9013fdca9c93e278c","path":"/openscope_databook/build/8499ee025631edb9013fdca9c93e278c.json"}}},"children":[],"key":"Eke6tf7S96"}],"visibility":"show","key":"TiOBEnAN1Z"}],"visibility":"show","key":"x71dd76GUA"},{"type":"anywidget","id":"figlightbox-1783916653701-so3fgo5","esm":"/openscope_databook/build/figure-lightbox-widg-a3820232e7fb9e218e214316425725fb.mjs","model":{},"key":"qI2O0i3aKp"}],"key":"EgN6cd3PtC"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Visualize 2P and Behavioral Data for Mouse Decision-making Task During Virtual Navigation","url":"/visualize-2p-vr-behavior","group":"Visualizing NWB Files"},"next":{"title":"Visualizing Stimulus Templates","url":"/visualize-templates","group":"Visualizing NWB Files"}}},"domain":"http://localhost:3000"}