ey":"D1Scj8pIc5"},{"type":"listItem","spread":true,"position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"children":[{"type":"paragraph","children":[{"type":"link","url":"https://portal.brain-map.org/explore/circuits/visual-coding-neuropixels","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"children":[{"type":"text","value":"here","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"sTlRe9oD2e"}],"urlSource":"https://portal.brain-map.org/explore/circuits/visual-coding-neuropixels","key":"jCMyp8lWdS"},{"type":"text","value":" is a visualization of the neuropixels probes that may come in handy when trying to visualize how the data is collected from the probe itself.","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"AyflyADzSB"}],"key":"sfP0zEkpZh"}],"key":"lfj7ND6usb"}],"key":"akpwlx64Nc"}],"key":"i9I9OQP24g"}],"key":"fMfJmMSOTq"},"references":{"cite":{"order":["Stosiek_2003"],"data":{"Stosiek_2003":{"label":"Stosiek_2003","enumerator":"1","doi":"10.1073/pnas.1232232100","html":"Stosiek, C., Garaschuk, O., Holthoff, K., & Konnerth, A. (2003). <i>In vivo</i> two-photon calcium imaging of neuronal networks. <i>Proceedings of the National Academy of Sciences</i>, <i>100</i>(12), 7319–7324. <a target=\"_blank\" rel=\"noreferrer\" href=\"https://doi.org/10.1073/pnas.1232232100\">10.1073/pnas.1232232100</a>","url":"https://doi.org/10.1073/pnas.1232232100"}}}},"footer":{"navigation":{"prev":{"title":"OpenScope Databook","url":"/","group":"OpenScope Databook"},"next":{"title":"Downloading an NWB File","url":"/download-nwb","group":"Basics"}}},"domain":"http://localhost:3000"}