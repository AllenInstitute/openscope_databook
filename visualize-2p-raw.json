"depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"2P Movie with ROI Mask","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"v9sm7riuod"}],"identifier":"id-2p-movie-with-roi-mask","label":"2P Movie with ROI Mask","html_id":"id-2p-movie-with-roi-mask","implicit":true,"key":"oFId48TRcs"}],"key":"lJg4l61Ak5"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"### overlaying ROIs onto 2P movie\n\nmovie_subset = np.array(movie[start_idx:end_idx])\nroi_masks_3d = np.reshape(roi_masks, (1,) + roi_masks.shape)\nm = movie_subset.mean()\n# mutltiply mask values for visibility\nroi_masks_3d = np.multiply(roi_masks_3d, m*10)\nmovie_masked = np.add(movie_subset, roi_masks_3d)","key":"E3tqQ3frNV"},{"type":"outputs","id":"X846CbQqVDxZV74E5NqHy","children":[],"key":"eGE8oG90Cy"}],"key":"pHLg1gwptz"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def hyperslicer(data, play_buttons=False, **kwargs):\n    img_widget = widgets.Image(format='png')\n    slider = widgets.IntSlider(min=0, max=len(data)-1, value=0, description='Frame')\n\n    def render_frame(frame):\n        fig, ax = plt.subplots()\n        ax.tick_params(left=False, bottom=False, labelleft=False, labelbottom=False)\n        ax.imshow(data[frame], **kwargs)\n        buf = io.BytesIO()\n        fig.savefig(buf, format='png', bbox_inches='tight')\n        plt.close(fig)\n        buf.seek(0)\n        img_widget.value = buf.read()\n\n    render_frame(0)\n    slider.observe(lambda change: render_frame(change['new']), names='value')\n    display(widgets.VBox([img_widget, slider]))","key":"RGZ73KzjoS"},{"type":"outputs","id":"SA5tikB1j5_ernt9d8RHx","children":[],"key":"hj96uxWeL4"}],"key":"HbdqfXyng0"},{"type":"block","kind":"notebook-code","data":{"scrolled":false},"children":[{"type":"code","lang":"python","executabl