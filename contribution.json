[{"type":"text","value":"Then the environment must be set up. The preferred local setup is Python 3.10 with ","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"SZJtjgxMWs"},{"type":"inlineCode","value":"uv","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"pbv1YG2rnT"},{"type":"text","value":", which mirrors CI and lockfile resolution. After cloning, run ","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"f9wnkXBXcp"},{"type":"inlineCode","value":"python -m pip install uv","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"GZisTnkqB9"},{"type":"text","value":" followed by ","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"AVSFM8zg8Y"},{"type":"inlineCode","value":"uv sync --frozen --extra dev --python 3.10","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"VQZ1lRBOjy"},{"type":"text","value":". If you prefer not to use ","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"JtKafwljMw"},{"type":"inlineCode","value":"uv","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"ax7eIrf3et"},{"type":"text","value":", create a Python 3.10 environment and install with ","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"YahG1e6BjB"},{"type":"inlineCode","value":"python -m pip install -r requirements-ci.txt","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"g0z8LEJ1ID"},{"type":"text","value":" and ","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"eTCCDa4UJ3"},{"type":"inlineCode","value":"python -m pip install -e .","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"PzzaQbbN3T"},{"type":"text","value":".","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"ESzdveZM6b"}],"key":"qgaii6nQH8"},{"type":"paragraph","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"Finally, notebooks can be run with Jupyter notebook by running ","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"Go15mdXKxB"},{"type":"inlineCode","value":"uv run jupyter notebook ./docs","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"ogRobm12GA"},{"type":"text","value":" (or ","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"M3dD5nRhVX"},{"type":"inlineCode","value":"jupyter notebook ./docs","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"KUc2JsdhEy"},{"type":"text","value":" in an already-activated pip environment).","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"CW678Gxp1F"}],"key":"Nhh1MPUg1q"},{"type":"heading","depth":2,"position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"Make Contributions","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"dHoQjiDtcd"}],"identifier":"make-contributions","label":"Make Contributions","html_id":"make-contributions","implicit":true,"key":"gIkjpGkk2r"},{"type":"paragraph","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"A contribution can take the form of changes to an existing notebook. More likely, it will be in adding a new analysis notebook to the databook. First, determine which ","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"tyBFHtDNPI"},{"type":"emphasis","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"chapter","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"QPKT7IHuKk"}],"key":"ivoBiZkQFX"},{"type":"text","value":" it will go into within the ","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"jQDXvrd17R"},{"type":"inlineCode","value":"./docs","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"n4VPjogphI"},{"type":"text","value":" directory, and create a new ","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"lLl7JpZ2vR"},{"type":"inlineCode","value":".ipynb","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"JOwT3W5i42"},{"type":"text","value":" file there. Then the notebook can be produced with the analysis and reproducible figures. For a contribution to be accepted it must adhere to the contribution ","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"kpRCWovVg5"},{"type":"strong","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"Styleguide","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"UnTdNCkA9Y"}],"key":"DQsbFrxRkj"},{"type":"text","value":" below. In addition to having clean code and clear figures, it is important that the notebook has thorough markdown explaining the figures and the analysis performed.","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"R3ZCj06Sxy"}],"key":"UD8hO8KwqR"},{"type":"paragraph","position":{"start":{"line":19,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"strong","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"Important Note:","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"mriOS89DdT"}],"key":"H4gAmDcoV8"},{"type":"text","value":"\nFor a notebook to be compliant with the Databook, it must have an environment setup cell at the top. This is described in the ","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"N7XkQ937x8"},{"type":"strong","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"Styleguide","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"xwh55t8SlN"}],"key":"POZzXydNUR"},{"type":"text","value":" below.","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"P47x6CEpIx"}],"key":"VbeIFqPVH6"},{"type":"paragraph","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"text","value":"Any additional packages required for the notebook to run should be added to ","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"B3YUpifMD8"},{"type":"inlineCode","value":"pyproject.toml","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"Ukxw0J2RoE"},{"type":"text","value":", then lock/export artifacts should be updated with ","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"L7PADccaX8"},{"type":"inlineCode","value":"uv lock","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"CYRT6gutjT"},{"type":"text","value":" and ","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"TbfOeUytUN"},{"type":"inlineCode","value":"uv export --frozen --no-dev --no-emit-project --no-hashes -o requirements-ci.txt","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"EVGNolgmCd"},{"type":"text","value":". When the notebook is complete it must be added to ","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"wJq4ZFWXNA"},{"type":"inlineCode","value":"docs/_toc.yml","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"bUdwRQwcQl"},{"type":"text","value":" to the appropriate chapter.","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"C0CfWRlPRN"}],"key":"yX1j7jMQ4r"},{"type":"heading","depth":2,"position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"children":[{"type":"text","value":"Run and Test Locally","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"tVTaeO4r6t"}],"identifier":"run-and-test-locally","label":"Run and Test Locally","html_id":"run-and-test-locally","implicit":true,"key":"UhfG617yr2"},{"type":"paragraph","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"children":[{"type":"text","value":"Prior to pushing, the notebook should be tested locally. It should be ensured that it runs from beginning to end without interruption and produces clean-looking figures. To confirm everything is configured properly, the Jupyter book should be built and examined with the command ","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"key":"JAMZigpsIC"},{"type":"inlineCode","value":"jupyter-book build ./docs","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"key":"qm8Isfd6LD"},{"type":"text","value":".","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"key":"iOuTAxkiF4"}],"key":"Ymygaxq8U3"},{"type":"heading","depth":2,"position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"children":[{"type":"text","value":"Commit, Push and Make a Pull Request","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"key":"haIzBuBhsM"}],"identifier":"commit-push-and-make-a-pull-request","label":"Commit, Push and Make a Pull Request","html_id":"commit-push-and-make-a-pull-request","implicit":true,"key":"F4ZGKBATDO"},{"type":"paragraph","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"children":[{"type":"text","value":"Local progress can be saved with ","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"w5gyoqWGiY"},{"type":"inlineCode","value":"git commit","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"wHtxSm4Quc"},{"type":"text","value":" and then pushed to the remote fork with ","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"cZHcYIPAwe"},{"type":"inlineCode","value":"git push","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"NBCExLIMMZ"},{"type":"text","value":". See this ","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"wqunk8OnYe"},{"type":"link","url":"https://www.atlassian.com/git/tutorials/saving-changes/git-commit","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"children":[{"type":"text","value":"Git tutorial","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"M6G5jBTTCp"}],"urlSource":"https://www.atlassian.com/git/tutorials/saving-changes/git-commit","key":"nuLoNORs0C"},{"type":"text","value":" for more information on how to do this.","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"LggU0N26Cz"}],"key":"E8yPrAxRn0"},{"type":"paragraph","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"children":[{"type":"text","value":"A PR can then be made to the original OpenScope Databook repo. On the forked repo front page, first make sure to press the ","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"key":"AxcGA6RVhP"},{"type":"inlineCode","value":"sync fork","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"key":"Yfy5NOutbt"},{"type":"text","value":" button, and then ","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"key":"h6xll3nVgd"},{"type":"inlineCode","value":"contribute","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"key":"pgk1OYL1S9"},{"type":"text","value":" can be pressed to make a PR. It is advised to make the PR into the Databook’s dev branch rather than the main branch.","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"key":"J2H6xnW09Y"}],"key":"pSbmP1nBkk"},{"type":"heading","depth":2,"position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"children":[{"type":"text","value":"Interact on ReviewNB","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"Xb6tDVFMX7"}],"identifier":"interact-on-reviewnb","label":"Interact on ReviewNB","html_id":"interact-on-reviewnb","implicit":true,"key":"n8ULxfLpQV"},{"type":"paragraph","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"text","value":"Once the pull request is made, it will be reviewed for merging into the Databook. This process can be monitored on the PR page, where there will be a purple button linking to ","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"key":"HJa35NTvYV"},{"type":"link","url":"https://www.reviewnb.com/","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"text","value":"ReviewNB","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"key":"e5VOjK2Mls"}],"urlSource":"https://www.reviewnb.com/","key":"FrB0UrYGbh"},{"type":"text","value":". ReviewNB allows for the additions and changes made to notebooks to be easily viewed and commented on. Please check this for any feedback provided by the Databook team and make revisions accordingly. Once the PR is merged, you will be added to the authors list of the Databook.","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"key":"hrHliN7sfP"}],"key":"MQe6lTAUXj"},{"type":"heading","depth":2,"position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"children":[{"type":"text","value":"Reviewing the Databook","position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"key":"wNzLf2Ssb0"}],"identifier":"reviewing-the-databook","label":"Reviewing the Databook","html_id":"reviewing-the-databook","implicit":true,"key":"V2tAeAMR7K"},{"type":"paragraph","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"children":[{"type":"text","value":"Reviews of the Databook are also made on G