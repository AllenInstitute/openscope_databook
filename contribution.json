{"version":3,"kind":"Article","sha256":"e77f26f473d7bd2831984742a8c113e41d453886ada0496581f2d7b427fdcbc3","slug":"contribution","location":"/contribution.md","dependencies":[],"frontmatter":{"title":"Contributing to the Databook","content_includes_title":false,"github":"https://github.com/AllenInstitute/openscope_databook","numbering":{"title":{"offset":1}},"source_url":"https://github.com/AllenInstitute/openscope_databook/blob/main/docs/contribution.md","edit_url":"https://github.com/AllenInstitute/openscope_databook/edit/main/docs/contribution.md","exports":[{"format":"md","filename":"contribution.md","url":"/build/contribution-b01ab3d7a8e6a4b0a8f46a888beb6458.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"The OpenScope Databook is a community project. It aims to serve as a collection of contributed analyses from many different experts and to include a comprehensive set of useful and reproducible analyses. Contributors are added to the authors list and have an opportunity to share their figures, results, and datasets through their notebooks in the Databook. Together the project can grow and continue to shape the growing reproducible neuroscience ecosystem.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Z7Dqt3zIUv"}],"key":"xPaGOY6YXf"},{"type":"heading","depth":2,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Fork the OpenScope Databook","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"omUwsH7iiu"}],"identifier":"fork-the-openscope-databook","label":"Fork the OpenScope Databook","html_id":"fork-the-openscope-databook","implicit":true,"key":"F83Wx3oiMX"},{"type":"paragraph","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"The Databook can be 