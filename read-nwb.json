ve_tree\n    download.download(\n        zarr_file.download_url,\n        output_dir=download_loc,\n        preserve_tree=True,\n    )\n    print(f\"Downloaded Zarr store to {zarr_filepath}\")\nelse:\n    print(\"Zarr store already exists\")\n\nif not os.path.exists(zarr_filepath):\n    raise FileNotFoundError(f\"Zarr store not found at expected path: {zarr_filepath}\")\n\nzarr_io = NWBZarrIO(path=zarr_filepath, mode=\"r\")\nzarr_nwb = zarr_io.read()\nzarr_nwb;","key":"lMRiGO5OVt"},{"type":"outputs","id":"zBalEF0mC8-qz6t2YrKTn","children":[],"key":"XfLUlVI3bi"}],"key":"SCfDBXH0F8"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"### uncomment these to view aspects of the file\n\n### not all of these exist for all NWB files (Key Errors will arise if the fields don't exist for this file)\n\n# nwb.identifier\n# nwb.processing\n# nwb.acquisition[\"events\"]\n# nwb.intervals[\"trials\"]\n# nwb.stimulus[\"StimulusPresentation\"]\n# nwb.electrodes","key":"N5sisIxU3Y"},{"type":"outputs","id":"CsUo6HX7AFDP-Yps-tTvi","children":[],"key":"MSE2NVjxaY"}],"key":"K0tbicQXFP"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"OpenScope’s File Schemas","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"YEpeU8NNig"}],"identifier":"openscopes-file-schemas","label":"OpenScope’s File Schemas","html_id":"openscopes-file-schemas","implicit":true,"key":"nEzTrqcjBB"},{"type":"paragraph","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"OpenScope works with two main types of brain data files for different experiments. There’s Extracellular Electrophysiology, ","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"g4FweKq3db"},{"type":"emphasis","position":{"start":{"line":2,"column":1},"en