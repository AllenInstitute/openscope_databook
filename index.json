JGfepj"},{"type":"text","value":". Alternatively, you can clone the repo to your machine and access the files there. The repo can be found by clicking the ","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"Xp3tFYtllR"},{"type":"inlineCode","value":"GitHub","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"gqWgM2Rbdj"},{"type":"text","value":" button in the top-right.","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"HY688eXb4A"}],"key":"v7XjyjX2xQ"},{"type":"code","lang":"","value":"git clone --depth 1 https://github.com/AllenInstitute/openscope_databook.git","position":{"start":{"line":43,"column":1},"end":{"line":45,"column":1}},"key":"Z7xmFFSuqZ"},{"type":"heading","depth":4,"position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"children":[{"type":"text","value":"Locally (Preferred: uv)","position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"key":"GYTfeIIgG1"}],"label":"locally-preferred-uv","identifier":"locally-preferred-uv","html_id":"locally-preferred-uv","key":"LoGubLmgvg"},{"type":"paragraph","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"children":[{"type":"text","value":"Use Python 3.13. Then install and sync with:","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"c4n9Ovoi6y"}],"key":"QfUpYNmaN1"},{"type":"code","lang":"","value":"python -m pip install uv\nuv sync --frozen --extra dev --python 3.13","position":{"start":{"line":50,"column":1},"end":{"line":53,"column":1}},"key":"wAz5EhyJiG"},{"type":"paragraph","position":{"start":{"line":54,"column":1},"end":{"line":54,"column":1}},"children":[{"type":"text","value":"Run notebooks/tools through uv (for example):","position":{"start":{"line":54,"column":1},"end":{"line":54,"column":1}},"key":"hEbij0NdaG"}],"key":"v71Jy0gZX4"},{"type":"code","lang":"","value":"uv run jupyter notebook ./docs","position":{"start":{"line":55,