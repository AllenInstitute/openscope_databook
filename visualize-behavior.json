 ecephys NWB file and plot them.","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"CLLn3OLp37"}],"key":"H3QbjZRUxA"}],"key":"jeQiCTfEkj"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Environment Setup","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"q0cG462wTC"}],"identifier":"environment-setup","label":"Environment Setup","html_id":"environment-setup","implicit":true,"key":"ZFOocewxYa"},{"type":"paragraph","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"⚠️","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"OsSmysWCoo"},{"type":"strong","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"Note: If running on a new environment, run this cell once and then restart the kernel","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"I33rsLOb5S"}],"key":"rRP98nVa3f"},{"type":"text","value":"⚠️","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"fUSCAL0vTj"}],"key":"F115gZ0ai5"}],"key":"RUv2cT8oTg"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"try:\n    from databook_utils.dandi_utils import dandi_stream_open\nexcept:\n    !git clone --depth 1 https://github.com/AllenInstitute/openscope_databook.git\n    %cd openscope_databook\n    %pip install -e .","key":"tdl8B2nSIl"},{"type":"outputs","id":"YKKjU35egDYW4v5yMhyq0","children":[],"key":"KwwLq6hXCZ"}],"key":"Ub0Jgi6wh5"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\n\nimport matplotlib.pyplot as plt\nimport numpy as np\n\n%matplotlib inline","key":"tKkVRqbyVm"},{"type":"outputs","id":"EjNdgDLJ5KEwYFb_5h6eZ","children":[],"key":"K4Ote9sWb8"}],"key":"Oc77D24Klh"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Streaming NWB File","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Z52zRWvptp"}],"identifier":"streaming-nwb-file","label":"Streaming NWB File","html_id":"streaming-nwb-file","implicit":true,"key":"vfczJ2ww7m"},{"type":"paragraph","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"Streaming a file from DANDI requires information about the file of interest. The current information below is for data that is private to the Allen Institute. Set ","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"U4pksga12c"},{"type":"inlineCode","value":"dandiset_id","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"xF6qzkO8t1"},{"type":"text","value":" to be the ID of the dandiset you want, and set ","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"l4k5tUwTyj"},{"type":"inlineCode","value":"dandi_filepath","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"UjAISVQbWs"},{"type":"text","value":" to be the path of the file within the dandiset. The filepath can be found if you press on the ","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"l4rXQ4NXNm"},{"type":"inlineCode","value":"i","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"D5T5V7tGkz"},{"type":"text","value":" icon of a file and copy the ","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"RJMj8U7hPB"},{"type":"inlineCode","value":"path","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"phRkoc2iOG"},{"type":"text","value":" field that shows up in the resulting JSON. If you are accessing embargoed data, you will need to set ","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"H2E99UtP5K"},{"type":"inlineCode","value":"dandi_api_key","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"maAva49lGh"},{"type":"text","value":" to your DANDI API key.","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"fnzyMBr4Vy"}],"key":"dBnoMGSPMl"}],"key":"TZcn4in4c0"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"dandiset_id = \"000336\"\ndandi_filepath = \"sub-621602/sub-621602_ses-1193555033-acq-1193675745_ophys.nwb\"\n\n# use for OpenScope Predictive Processing Community Project NWBs\n# dandiset_id = \"001768\"\n# dandi_filepath = \"sub-839909/sub-839909_ses-multiplane-ophys-839909-2026-02-20-12-53-27_ophys.nwb\"","key":"eDephmGEd6"},{"type":"outputs","id":"nmvu8wbuoja_WaZOdhkxs","children":[],"key":"pupP5CJTl3"}],"key":"GHnedxKPsK"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# This can sometimes take a while depending on the size of the file\nio = dandi_stream_open(dandiset_id, dandi_filepath)\nnwb = io.read()","key":"xMDXOwj3fN"},{"type":"outputs","id":"CwlQIbJzIcHRgXaNxyx1w","children":[],"key":"tLb9iXFXXP"}],"key":"So7YTcVEpp"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Extracting Eye Tracking Data","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"YD7CqCK61G"}],"identifier":"extracting-eye-tracking-data","label":"Extracting Eye Tracking Data","html_id":"extracting-eye-tracking-data","implicit":true,"key":"NERRPdYIoC"},{"type":"paragraph","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"Our datasets include eye data with eye tracking, corneal reflection tracking, and pupil tracking. These are different visual components identified in footage of the mouse during the experiment. Any of these could be usable for the following analyses. Each eye tracking type includes measurements of the angle of the eye and the height, width, and area (in terms of pixels on the camera), and the coordinates of the center of the component.","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"Umj8afA7az"}],"key":"ucTg94fCc9"},{"type":"paragraph","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"The cell below auto-detects which NWB format is present and normalizes the data into plain numpy arrays used by all cells below:","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"noZSds9ise"}],"key":"akNK1iRiaL"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":5,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Older NWBs","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"PTmLPHT8N5"}],"key":"VxlxVckEcD"},{"type":"text","value":" (standard ecephys/ophys): eye tracking in ","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"XNOpesIHVg"},{"type":"inlineCode","value":"nwb.acquisition[\"EyeTracking\"]","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"VCDbnG1EmC"},{"type":"text","value":" as SpatialSeries. Area is available.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"HywTXKJVYM"}],"key":"zW11bdH3UJ"}],"key":"xTAqx31hhg"},{"type":"listItem","spread":true,"position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"Newer NWBs","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"vxZPQpTbMN"}],"key":"qJlmQUKja5"},{"type":"text","value":" (multiplane ophys): eye tracking in ","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"wDGIwpVJDw"},{"type":"inlineCode","value":"nwb.processing[\"eye_tracking\"]","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"H2Hwtc22IW"},{"type":"text","value":" as DynamicTables. Area may not be available.","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"drHTPxeQ9F"}],"key":"vUaAKLZocl"}],"key":"KIu0YBzohx"}],"key":"TEjh4MuSa5"}],"key":"a6QHcKJkmA"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"if \"EyeTracking\" in nwb.acquisition:\n    # Older NWBs: eye tracking in nwb.acquisition[\"EyeTracking\"] as SpatialSeries\n    et = nwb.acquisition[\"EyeTracking\"]\n    eye_tracking = et.eye_tracking\n    timestamps  = np.array(eye_tracking.timestamps)\n    blink_times = np.array(et.likely_blink.data)\n    eye_width   = np.array(eye_tracking.width)\n    eye_height  = np.array(eye_tracking.height)\n    eye_angle   = np.array(eye_tracking.angle)\n    eye_xs      = np.array([pt[0] for pt in eye_tracking.data])\n    eye_ys      = np.array([pt[1] for pt in eye_tracking.data])\n    has_eye_area = hasattr(eye_tracking, \"area\") and eye_tracking.area is not None\n    eye_area     = np.array(eye_tracking.area) if has_eye_area else None\nelse:\n    # Newer NWBs: eye tracking in nwb.processing[\"eye_tracking\"] as DynamicTables\n    et_table    = nwb.processing[\"eye_tracking\"][\"ellipse\"]\n    timestamps  = np.array(et_table[\"timestamps\"][:])\n    blink_times = np.array(nwb.processing[\"eye_tracking\"][\"likely_blink_times\"].data)\n    eye_width   = np.array(et_table[\"width\"][:])\n    eye_height  = np.array(et_table[\"height\"][:])\n    eye_angle   = np.array(et_table[\"angle\"][:])\n    eye_xs      = np.array(et_table[\"data_x\"][:])\n    eye_ys      = np.array(et_table[\"data_y\"][:])\n    has_eye_area = \"area\" in et_table.colnames\n    eye_area     = np.array(et_table[\"area\"][:]) if has_eye_area else None\n\nprint(timestamps.shape)","key":"RdatBzAxFe"},{"type":"outputs","id":"tSj4kRHA9H8sX7yViU4nH","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"(241673,)\n"},"children":[],"key":"C5BJkey9vR"}],"key":"LgHVQVRaZj"}],"key":"O38BF5x218"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Selecting a Period","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"XHWKjzNi3k"}],"identifier":"selecting-a-period","label":"Selecting a Period","html_id":"selecting-a-period","implicit":true,"key":"HXZPDQw5Os"},{"type":"paragraph","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"The data can be large or messy. In order to visualize the data more cleanly and efficiently, you can just select a period of time within the data to plot. To do this, specify the ","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"vXkGh7YJQG"},{"type":"inlineCode","value":"start_time","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"lMxX24s67t"},{"type":"text","value":" and ","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"aMELE4MTHh"},{"type":"inlineCode","value":"end_time","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"hEQInNTaGV"},{"type":"text","value":" you’d like in terms of seconds. Below, the first and last timestamps from the data are printed to inform this choice. Once you input your start time and end time in seconds, those times will be translated into indices so the program can identify what slice of data to select.","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"zmxXgsumoV"}],"key":"Wlcxb45qHc"}],"key":"cAy5tzlMlx"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"print(timestamps[0])\nprint(timestamps[-2]) # not [-1] because that's NaN","key":"z5cZxftvsN"},{"type":"outputs","id":"Y6n-hmd5CzSWF6F9DiN8v","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"0.20801\n4027.98269\n"},"children":[],"key":"HNzJBJ94ju"}],"key":"W8lpPK1YGl"}],"key":"YyJ25bLWqB"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"start_time = 1000\nend_time = 1200","key":"Vsoo7IJWRJ"},{"type":"outputs","id":"a7WutOzHASdM7eHjmAQBn","children":[],"key":"uMjdtToLpQ"}],"key":"ev9MfuDggz"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"### translate times to data indices using timestamps\n\nstart_idx, end_idx = None, None\nfor i, ts in enumerate(timestamps):\n    if not start_idx and ts >= start_time:\n        start_idx = i\n    if start_idx and ts >= end_time:\n        end_idx = i\n        break\n\nif start_idx == None or end_idx == None:\n    raise ValueError(\"Time bounds not found within eye tracking timestamps\")","key":"lSeCKe5yN7"},{"type":"outputs","id":"UDk8-vXau7JNP93hS2wVJ","children":[],"key":"Fz0IY0ijpf"}],"key":"zkHYmkkhiO"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# make time axis\ntime_axis = np.arange(start_idx, end_idx)","key":"u0o4LhwLsj"},{"type":"outputs","id":"gT2EPZHhypSLIoSqfmzVz","children":[],"key":"XxVX5IlHLs"}],"key":"NIZP5QN1AJ"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Visualizing the Data","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"IrNEkRpePa"}],"identifier":"visualizing-the-data","label":"Visualizing the Data","html_id":"visualizing-the-data","implicit":true,"key":"U0V9QXZs98"},{"type":"paragraph","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"Below, several types of measurements are visualized from the eye tracking data that was selected.","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"sOL7glsKyf"}],"key":"yl9ryMkLm8"}],"key":"jNE8bNB2od"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Blink Times","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"fSeT6fuLUq"}],"identifier":"blink-times","label":"Blink Times","html_id":"blink-times","implicit":true,"key":"hFg2tJumAZ"}],"key":"UaBfmU7PS2"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig, ax = plt.subplots()\nax.plot(time_axis, blink_times[start_idx:end_idx], linewidth=0.2)\nax.set_xlabel(\"time (s)\")\nax.set_title(\"Blink Times\")","key":"gGFck7955X"},{"type":"outputs","id":"gDNS2NVao17wGu3Ds1LuX","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"6b8043c32ce4011c0a43dda637b8aaa8","path":"/openscope_databook/build/6b8043c32ce4011c0a43dda637b8aaa8.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"HsdT6jRpEP"}],"key":"YYtkOSJnoc"}],"key":"KQt8E2cC6i"},{"type":"block","kind":"notebook-content","children":[{"ty