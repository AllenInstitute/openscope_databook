, eye_area[start_idx:end_idx])\nelse:\n    print(\"Area data not available for this NWB file.\")","key":"ERNuqdzSu8"},{"type":"outputs","id":"AmGHz4NYHCRp3gTEN346w","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"9453206cdacf6eb45782fb57b0c3f1a0","path":"/openscope_databook/build/9453206cdacf6eb45782fb57b0c3f1a0.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"piVdMZpIyW"}],"key":"TzoxhNohzq"}],"key":"VLDFvPfzVU"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Angle","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"H3w7GdV8ea"}],"identifier":"angle","label":"Angle","html_id":"angle","implicit":true,"key":"cP7NBPzBMA"}],"key":"BU7wIxO1hi"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig, ax = plt.subplots()\nax.set_xlabel('time (s)')\nax.set_ylabel('angle (degrees)')\nax.set_title(\"Eye Angle Over Time\")\nax.plot(time_axis, eye_angle[start_idx:end_idx])","key":"EkGHmejCcY"},{"type":"outputs","id":"H7y0mslPa3c4AqF7eXfWV","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"3dcac60fcc59e5bf62e6a0b3d491a7b7","path":"/openscope_databook/build/3dcac60fcc59e5bf62e6a0b3d491a7b7.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"EdKXIPbpH8"}],"key":"A5DSR8uXhO"}],"key":"CFy4I9H8ck"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Eye Trace","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"m9Q3mwQXSw"}],"identifier":"eye-trace","label":"Eye Trace","html_id":"eye-trace","implicit":true,"key":"tEA3s1kdq9"},{"type":"paragraph","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"With marker color representing time, the x and y coordinates of the eye’s view are traced below.","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"CZ7BxOyG9v"}],"key":"XKlK3YgJEs"}],"key":"ZdZQ7ICCYW"},{"type":"block","kind":"notebook-code","data":{"scrolled":false},"children":[{"type":"code","lang":"python","executable":true,"value":"fig, ax = plt.subplots()\ncolors = plt.cm.viridis(np.linspace(0, 1, end_idx-start_idx))\nax.plot(eye_xs[start_idx:end_idx], eye_ys[start_idx:end_idx], zorder=0, linewidth=0.25)\nax.scatter(eye_xs[start_idx:end_idx], eye_ys[start_idx:end_idx], s=5, c=colors, zorder=1)\n\n# change these to set the plot limits\n# ax.set_xlim(310,360)\n# ax.set_ylim(270,320)\n\nax.set_xlabel(\"x pixel\")\nax.set_ylabel(\"y pixel\")\nax.set_title(\"Eye Trace Through Time\")\nplt.show()","key":"IisKMfntNc"},{"type":"outputs","id":"yUF2yvK6EFFJlgKjmWWFH","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"d92225a2ded2865cf98bbccaeaed506c","path":"/openscope_databook/build/d92225a2ded2865cf98bbccaeaed506c.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"pQROhjG23I"}],"key":"DTWgnup8KQ"}],"key":"JkcSc036cJ"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Running Data","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"d9Yk6MX7mV"}],"identifier":"running-data","label":"Running Data","html_id":"running-data","implicit":true,"key":"tqu2twow8M"},{"type":"paragraph","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"Apart from the Eye Tracking Data, the mouse’s running data is tracked in the ","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"wgNbWw7t6j"},{"type":"inlineCode","value":"\"running\"","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"DDaODxUUYS"},{"type":"text","value":" field of the ","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"jX7t1QZBho"},{"type":"inlineCode","value":"processing","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"sTQCNFYCQY"},{"type":"text","value":" section of the NWB File. Speed, in cm/s is tracked in the ","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"jBKwfGMzr4"},{"type":"inlineCode","value":"\"speed\"","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"t74zuOnK9M"},{"type":"text","value":" field. Another field, ","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"BfcWpE16ve"},{"type":"inlineCode","value":"\"dx\"","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"g6KAgqPqUU"},{"type":"text","value":" is also recorded which represents the number of degrees the wheel has turned between timestamp. These are plotted below. It is important to note that, at the moment, running data is stored in NWB differently in our Ecephys files and our Ophys files. Change the code in the cell below if you’re accessing a different type of file.","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"dcdwDHFlwL"}],"key":"uqpYWPsIRJ"}],"key":"EufpTh0PT0"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"running = nwb.processing[\"running\"]\nrunning_speed  = running[\"speed\"] if \"speed\" in running.keys() else running[\"running_speed\"]\nwheel_rotation = running[\"dx\"] if \"dx\" in running.keys() else running[\"running_wheel_rotation\"]","key":"iB3wfXrEr1"},{"type":"outputs","id":"m70aKU1_Ofr4rsqsgi6ZR","children":[],"key":"CM2Z2Rr0ft"}],"key":"O6CJNUsadq"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Running Speed","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"sTioC0GZ17"}],"identifier":"running-speed","label":"Running Speed","html_id":"running-speed","implicit":true,"key":"PhJ1wGCLpj"},{"type":"paragraph","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"Below are the running speed over time and wheel rotation over time. They should probably look very similar. Additionally, we show the distribution of the timestamp deltas. If the data was processed properly, there shouldn’t be many deviations. However, sometimes, individual frames might be dropped during processing from the experimental rigs which could show some diffs that are double what the expected value is.","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"lw4NqkcGe1"}],"key":"q5q71bV9Dj"}],"key":"fOmJVWo2b5"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"speed_data = np.array(running_speed.data)\nspeed_timestamps = np.array(running_speed.timestamps)\nprint(speed_data.shape)\nprint(speed_timestamps.shape)\n\nfig, ax = plt.subplots()\nax.set_xlabel(\"time (s)\")\nax.set_ylabel(\"speed (cm/s)\")\nax.set_title(\"Running Speed Over Time\")\nax.plot(speed_timestamps, speed_data)","key":"j1hJLXWnCK"},{"type":"outputs","id":"e1_iscy2ue-ZSWcSytTRL","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"(236232,)\n(236232,)\n"},"children":[],"key":"BD8GnydEHY"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"8241e4687042ed5b9d9cedd1802b29a6","path":"/openscope_databook/build/8241e4687042ed5b9d9cedd1802b29a6.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"qA2tA3AEbg"}],"key":"fSDRZlWlEu"}],"key":"pRwFVMjl5m"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig, ax = plt.subplots()\nax.hist(np.diff(speed_timestamps), 100)\nax.set_xlabel(\"Delta (s)\")\nax.set_ylabel(\"# Deltas\")\nax.set_title(\"Running Timestamp Deltas Histogram\")\nplt.show()","key":"TuUJzFv3S8"},{"type":"outputs","id":"oocag6Mr_-8xlF2_NqQ0u","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"5195d3eefa577f411c06182dae3765dc","path":"/openscope_databook/build/5195d3eefa577f411c06182dae3765dc.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"OlSlGcALko"}],"key":"ijEdNE8XmB"}],"key":"rFVWYjxdaR"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"rotation_data = np.array(wheel_rotation.data[1:]) # cut out first value since it is high outlier\nrotation_timestamps = np.array(wheel_rotation.timestamps[1:])\nprint(rotation_data.shape)\nprint(rotation_timestamps.shape)\n\nfig, ax = plt.subplots()\nax.set_xlabel(\"time (s)\")\nax.set_ylabel(\"rotation (degrees)\")\nax.set_title(\"Wheel Rotation Over Time\")\nax.plot(rotation_timestamps, rotation_data)","key":"s3CCohNlQ9"},{"type":"outputs","id":"TMT3y2QeqhfvAkoYhViIT","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"(236231,)\n(236231,)\n"},"children":[],"key":"QjlHWap7gL"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png"